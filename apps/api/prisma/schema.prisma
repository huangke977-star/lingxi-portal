generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  active
  disabled
}

enum PortalCategoryKind {
  navigation
  tool
  server
  custom_page
}

enum PortalVisibility {
  public
  authenticated
  role_restricted
}

enum PortalRecordStatus {
  active
  disabled
}

enum ArticleStatus {
  draft
  published
  unpublished
  blocked
  deleted
}

enum ArticleVisibility {
  public
  authenticated
  role_restricted
  private
}

enum ArticleCommentStatus {
  active
  blocked
  deleted
}

model Role {
  id               Int               @id @default(autoincrement())
  code             String            @unique @db.VarChar(64)
  name             String            @db.VarChar(64)
  level            Int               @unique
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  portalEntryRoles PortalEntryRole[]
  articleAllowedRoles ArticleAllowedRole[]

  @@map("roles")
}

model User {
  id                      Int               @id @default(autoincrement())
  username                String            @unique @db.VarChar(32)
  nickname                String            @db.VarChar(32)
  email                   String            @unique @db.VarChar(191)
  passwordHash            String            @map("password_hash") @db.VarChar(255)
  roleId                  Int               @map("role_id")
  role                    Role              @relation(fields: [roleId], references: [id])
  isSuperAdmin            Boolean           @default(false) @map("is_super_admin")
  status                  UserStatus        @default(active)
  appearanceThemeId       String            @default("sakura-mist") @map("appearance_theme_id") @db.VarChar(64)
  customAccent            String            @default("#db2777") @map("custom_accent") @db.VarChar(7)
  customSurface           String            @default("#ffffff") @map("custom_surface") @db.VarChar(7)
  customForeground        String            @default("#2b2530") @map("custom_foreground") @db.VarChar(7)
  customMuted             String            @default("#665867") @map("custom_muted") @db.VarChar(7)
  cardAlpha               Int               @default(52) @map("card_alpha")
  glassBlur               Int               @default(22) @map("glass_blur")
  glassTint               String            @default("#fff3f6") @map("glass_tint") @db.VarChar(7)
  glassTintAlpha          Int               @default(72) @map("glass_tint_alpha")
  avatarOriginalName      String?           @map("avatar_original_name") @db.VarChar(255)
  avatarStoredName        String?           @unique @map("avatar_stored_name") @db.VarChar(255)
  avatarMimeType          String?           @map("avatar_mime_type") @db.VarChar(64)
  avatarSizeBytes         Int?              @map("avatar_size_bytes")
  profileBio              String            @default("我懒，我不写") @map("profile_bio") @db.VarChar(180)
  lastLoginAt             DateTime?         @map("last_login_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  backgroundImages        BackgroundImage[]
  portalCategoriesCreated PortalCategory[]  @relation("PortalCategoryCreatedBy")
  portalCategoriesUpdated PortalCategory[]  @relation("PortalCategoryUpdatedBy")
  portalEntriesCreated    PortalEntry[]     @relation("PortalEntryCreatedBy")
  portalEntriesUpdated    PortalEntry[]     @relation("PortalEntryUpdatedBy")
  articles                Article[]         @relation("ArticleAuthor")
  articleComments         ArticleComment[]   @relation("ArticleCommentAuthor")
  articleLikes            ArticleLike[]
  articleFavorites        ArticleFavorite[]
  articleViews            ArticleView[]

  @@index([roleId])
  @@map("users")
}

model BackgroundImage {
  id           Int      @id @default(autoincrement())
  originalName String   @map("original_name") @db.VarChar(255)
  storedName   String   @unique @map("stored_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(64)
  sizeBytes    Int      @map("size_bytes")
  isActive     Boolean  @default(false) @map("is_active")
  uploadedById Int      @map("uploaded_by_id")
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([uploadedById])
  @@map("background_images")
}

model PortalCategory {
  id          Int                @id @default(autoincrement())
  kind        PortalCategoryKind
  name        String             @db.VarChar(80)
  slug        String             @unique @db.VarChar(80)
  description String             @default("") @db.VarChar(255)
  sortOrder   Int                @default(0) @map("sort_order")
  status      PortalRecordStatus @default(active)
  createdById Int?               @map("created_by_id")
  createdBy   User?              @relation("PortalCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById Int?               @map("updated_by_id")
  updatedBy   User?              @relation("PortalCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  entries     PortalEntry[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@index([kind, status, sortOrder])
  @@index([createdById])
  @@index([updatedById])
  @@map("portal_categories")
}

model PortalEntry {
  id           Int                @id @default(autoincrement())
  categoryId   Int                @map("category_id")
  category     PortalCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  title        String             @db.VarChar(100)
  description  String             @default("") @db.VarChar(300)
  url          String?            @db.VarChar(2048)
  iconPath     String?            @map("icon_path") @db.VarChar(512)
  openInNewTab Boolean            @default(true) @map("open_in_new_tab")
  visibility   PortalVisibility   @default(public)
  sortOrder    Int                @default(0) @map("sort_order")
  status       PortalRecordStatus @default(active)
  createdById  Int?               @map("created_by_id")
  createdBy    User?              @relation("PortalEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  Int?               @map("updated_by_id")
  updatedBy    User?              @relation("PortalEntryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  allowedRoles PortalEntryRole[]
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([categoryId, status, sortOrder])
  @@index([visibility])
  @@index([createdById])
  @@index([updatedById])
  @@map("portal_entries")
}

model PortalEntryRole {
  entryId Int         @map("entry_id")
  entry   PortalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  roleId  Int         @map("role_id")
  role    Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([entryId, roleId])
  @@index([roleId])
  @@map("portal_entry_roles")
}

model Article {
  id            Int                    @id @default(autoincrement())
  authorId      Int                    @map("author_id")
  author        User                   @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title         String                 @db.VarChar(120)
  slug          String                 @unique @db.VarChar(180)
  summary       String                 @default("") @db.VarChar(300)
  content       String                 @db.LongText
  coverPath     String?                @map("cover_path") @db.VarChar(512)
  category      String                 @default("") @db.VarChar(80)
  tags          String                 @default("") @db.VarChar(500)
  titleColor    String                 @default("") @map("title_color") @db.VarChar(7)
  visibility    ArticleVisibility      @default(public)
  status        ArticleStatus          @default(draft)
  isPinned      Boolean                @default(false) @map("is_pinned")
  pinOrder      Int                    @default(0) @map("pin_order")
  publishedAt   DateTime?              @map("published_at")
  blockedReason String?                @map("blocked_reason") @db.VarChar(255)
  viewCount     Int                    @default(0) @map("view_count")
  likeCount     Int                    @default(0) @map("like_count")
  favoriteCount Int                    @default(0) @map("favorite_count")
  commentCount  Int                    @default(0) @map("comment_count")
  allowedRoles  ArticleAllowedRole[]
  images        ArticleImage[]
  comments      ArticleComment[]
  likes         ArticleLike[]
  favorites     ArticleFavorite[]
  views         ArticleView[]
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  @@index([authorId, status, updatedAt])
  @@index([status, visibility, isPinned, pinOrder])
  @@index([category, status])
  @@map("articles")
}

model ArticleAllowedRole {
  articleId Int     @map("article_id")
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  roleId    Int     @map("role_id")
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([articleId, roleId])
  @@index([roleId])
  @@map("article_allowed_roles")
}

model ArticleImage {
  id           Int      @id @default(autoincrement())
  articleId    Int      @map("article_id")
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  originalName String   @map("original_name") @db.VarChar(255)
  storedName   String   @unique @map("stored_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(64)
  sizeBytes    Int      @map("size_bytes")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([articleId, sortOrder])
  @@map("article_images")
}

model ArticleComment {
  id        Int                  @id @default(autoincrement())
  articleId Int                  @map("article_id")
  article   Article              @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId  Int                  @map("author_id")
  author    User                 @relation("ArticleCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentId  Int?                 @map("parent_id")
  parent    ArticleComment?      @relation("ArticleCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ArticleComment[]     @relation("ArticleCommentReplies")
  body      String               @db.Text
  status    ArticleCommentStatus @default(active)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@index([articleId, status, createdAt])
  @@index([parentId])
  @@map("article_comments")
}

model ArticleLike {
  articleId Int      @map("article_id")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([articleId, userId])
  @@index([userId])
  @@map("article_likes")
}

model ArticleFavorite {
  articleId Int      @map("article_id")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([articleId, userId])
  @@index([userId])
  @@map("article_favorites")
}

model ArticleView {
  id         Int      @id @default(autoincrement())
  articleId  Int      @map("article_id")
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId     Int?     @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  visitorKey String   @map("visitor_key") @db.VarChar(191)
  viewedOn   String   @map("viewed_on") @db.VarChar(10)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([articleId, visitorKey, viewedOn])
  @@index([articleId, createdAt])
  @@map("article_views")
}
